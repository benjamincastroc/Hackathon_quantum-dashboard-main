# ─────────────────────────────────────────────────────────────
# GovWatch AI — Variables de entorno
# Copia este archivo a .env.local y rellena los valores reales.
# NUNCA subas .env.local al repositorio.
# ─────────────────────────────────────────────────────────────

# Groq API Key — modelo del agente y chat
# Obtén la tuya gratis en: https://console.groq.com → API Keys
GROQ_API_KEY=tu_api_key_aqui

# Tavily API Key — búsqueda web en tiempo real para el Agente Investigador
# Obtén la tuya gratis en: https://app.tavily.com → API Keys (1,000 búsquedas/mes gratis)
TAVILY_API_KEY=tu_api_key_aqui



SYSCOIN_PRIVATE_KEY=tu_private_api_key_aqui
SYSCOIN_ADDRESS=tu_public_address_key_aqui

# Supabase — base de datos para investigaciones y documentos
# Obtén las tuyas en: https://supabase.com → Project Settings → API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...